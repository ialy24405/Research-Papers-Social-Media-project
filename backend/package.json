{
	"name": "scholarstream-backend",
	"version": "1.0.0",
	"description": "Backend API for ScholarStream - Academic Paper Sharing Platform",
	"main": "dist/server.js",
	"scripts": {
		"dev": "ts-node-dev --respawn --transpile-only src/server.ts",
		"build": "tsc",
		"start": "node dist/server.js",
		"db:migrate": "node dist/config/migrate.js",
		"db:seed": "node dist/config/seed.js",
		"test:db": "node test-db-connection.js",
		"test": "jest",
		"test:watch": "jest --watch",
		"test:coverage": "jest --coverage"
	},
	"keywords": [
		"academic",
		"papers",
		"api",
		"express",
		"postgresql"
	],
	"author": "ScholarStream Team",
	"license": "MIT",
	"dependencies": {
		"express": "^4.18.2",
		"cors": "^2.8.5",
		"helmet": "^7.0.0",
		"morgan": "^1.10.0",
		"pg": "^8.11.3",
		"bcrypt": "^5.1.1",
		"jsonwebtoken": "^9.0.2",
		"joi": "^17.9.2",
		"multer": "^1.4.5-lts.1",
		"dotenv": "^16.3.1",
		"express-rate-limit": "^6.10.0"
	},
	"devDependencies": {
		"@types/express": "^4.17.17",
		"@types/cors": "^2.8.13",
		"@types/morgan": "^1.9.4",
		"@types/pg": "^8.10.2",
		"@types/bcrypt": "^5.0.0",
		"@types/jsonwebtoken": "^9.0.2",
		"@types/joi": "^17.2.3",
		"@types/multer": "^1.4.7",
		"@types/node": "^20.5.0",
		"@types/jest": "^29.5.5",
		"@types/supertest": "^2.0.12",
		"typescript": "^5.1.6",
		"ts-node": "^10.9.1",
		"ts-node-dev": "^2.0.0",
		"jest": "^29.7.0",
		"ts-jest": "^29.1.1",
		"supertest": "^6.3.3"
	}
}
